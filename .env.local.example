# ── Required ──────────────────────────────────────────────────────
DATABASE_URL="postgres://USER:PASSWORD@HOST/db?sslmode=require"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
INGEST_SECRET="generate-a-long-random-shared-secret"

# ── Auth URL ─────────────────────────────────────────────────────
# Local: http://localhost:3000
# Vercel: leave unset (inferred from VERCEL_URL)
# Non-Vercel hosting: set to the exact public HTTPS origin,
#   e.g. https://console.example.com
NEXTAUTH_URL="http://localhost:3000"

# ── Scheduled jobs ────────────────────────────────────────────────
CRON_SECRET="generate-a-long-random-cron-secret"

# ── AI (optional — graceful degradation without) ──────────────────
ANTHROPIC_API_KEY=""

# ── SFTP carrier keys (optional) ──────────────────────────────────
# Store the env var name in the carrier's sftp_key_env column.
# Example: SFTP_KEY_UPS for a carrier with sftp_key_env = 'SFTP_KEY_UPS'.
SFTP_KEY_SCAC=""

# ── Sentry (optional) ─────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ── Gateway API keys (per-client, optional) ───────────────────────
# Format: GATEWAY_API_KEY_<clientId>=sk-...
# The Gateway service reads these at startup. The key's tenant is
# the clientId embedded in the env var name — never from the request body.
# GATEWAY_API_KEY_client_abc123="sk-prod-..."
